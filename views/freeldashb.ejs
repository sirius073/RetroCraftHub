<!DOCTYPE html> 
<html lang="en"> 
  
<head> 
  <link rel="stylesheet" href="stylef.css">   
  <link rel="stylesheet" href="responsive.css"> 
  <meta charset="UTF-8"> 
    <meta http-equiv="X-UA-Compatible" content="IE=edge"> 
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
    <title>Freelancer Dashboard</title>
  
</head> 
  
<body> 
    <header> 
        <nav>
            <div class="logo">RetroCraftHub</div>
            <div>
                <a href="/freelprofile" class="profile-btn">Profile</a>
                <a href="#" class="search-btn">Job Page</a>
                <a href="/freelnotify" class="notification-icon">Notification </a>
                <a href="/login">Logout</a>
            </div>
        </nav>
    </header> 
    <div class="welcome-user">
        <h2>Welcome, <%= user.name %>!</h2>
        <p>Look out for the job that suits you best.</p>
    </div>
    
    <div >
          
        <div id="freelancer-cards-container">
            
              
              <% recruiters.forEach(recruiter => { %>
                <div class="freelancer-card">
                  <h3><%= recruiter.name %></h3>
                  <p>Job required: <%= recruiter.jobPreferences.job %></p>
                  <p>Job Experience required: <%= recruiter.jobPreferences.jobExperience %></p>
                  
                </div>
              <% }); %>
            
          </div>
          
            
        </div>
        
    </script> 
</body> 
</html>
